# Copy the same credential files you already use in ~/ggai/GGAiDoodle and point these
# environment variables at them before running `bundle exec fastlane ...`.

PRIVATECLAW_APP_STORE_CONNECT_KEY_ID=
PRIVATECLAW_APP_STORE_CONNECT_ISSUER_ID=
PRIVATECLAW_APP_STORE_CONNECT_KEY_FILE=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
PRIVATECLAW_APPLE_ID=
PRIVATECLAW_APPLE_TEAM_ID=
PRIVATECLAW_ITC_TEAM_ID=

PRIVATECLAW_PLAY_STORE_JSON_KEY=/absolute/path/to/playstore-service-account.json
PRIVATECLAW_ANDROID_KEYSTORE_PATH=/absolute/path/to/upload-keystore.jks
PRIVATECLAW_ANDROID_KEYSTORE_PASSWORD=
PRIVATECLAW_ANDROID_KEY_ALIAS=
PRIVATECLAW_ANDROID_KEY_PASSWORD=

# Optional mobile version overrides. Leave empty to use automatic store build numbering.
PRIVATECLAW_BUILD_NAME=
PRIVATECLAW_BUILD_NUMBER=
PRIVATECLAW_PLAY_RELEASE_STATUS=

# Store review behavior
PRIVATECLAW_AUTOMATIC_RELEASE=false
