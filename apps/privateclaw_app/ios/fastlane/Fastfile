require "json"
require "shellwords"

default_platform(:ios)

platform :ios do
  def privateclaw_app_root
    @privateclaw_app_root ||= File.expand_path("../..", __dir__)
  end

  def privateclaw_version_script_path
    @privateclaw_version_script_path ||= File.expand_path("../../../../scripts/resolve-mobile-version.mjs", __dir__)
  end

  def privateclaw_mobile_version
    @privateclaw_mobile_version ||= JSON.parse(
      sh("node #{Shellwords.escape(privateclaw_version_script_path)} --json")
    )
  end

  def privateclaw_build_name
    privateclaw_mobile_version.fetch("versionName")
  end

  def privateclaw_build_number
    privateclaw_mobile_version.fetch("buildNumber").to_s
  end

  def privateclaw_app_store_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("PRIVATECLAW_APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("PRIVATECLAW_APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("PRIVATECLAW_APP_STORE_CONNECT_KEY_FILE"),
      duration: 1200,
      in_house: false
    )
  end

  def privateclaw_signing_xcargs
    [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath #{Shellwords.escape(ENV.fetch('PRIVATECLAW_APP_STORE_CONNECT_KEY_FILE'))}",
      "-authenticationKeyID #{Shellwords.escape(ENV.fetch('PRIVATECLAW_APP_STORE_CONNECT_KEY_ID'))}",
      "-authenticationKeyIssuerID #{Shellwords.escape(ENV.fetch('PRIVATECLAW_APP_STORE_CONNECT_ISSUER_ID'))}"
    ].join(" ")
  end

  def privateclaw_prepare_ios_build_settings
    UI.message("Using PrivateClaw iOS version #{privateclaw_build_name} (#{privateclaw_build_number})")
    sh(
      "cd #{Shellwords.escape(privateclaw_app_root)} && flutter build ios --config-only --release " \
      "--build-name #{Shellwords.escape(privateclaw_build_name)} " \
      "--build-number #{Shellwords.escape(privateclaw_build_number)}"
    )
  end

  def privateclaw_testflight_external_groups
    groups = ENV.fetch("PRIVATECLAW_TESTFLIGHT_EXTERNAL_GROUPS", "ext")
      .split(",")
      .map(&:strip)
      .reject(&:empty?)
    UI.user_error!("Resolved TestFlight external group list is empty.") if groups.empty?
    groups
  end

  def privateclaw_notify_external_testers
    ENV["PRIVATECLAW_TESTFLIGHT_NOTIFY_EXTERNAL_TESTERS"] == "true"
  end

  def privateclaw_testflight_changelog
    value = ENV["PRIVATECLAW_TESTFLIGHT_CHANGELOG"]
    value.nil? || value.empty? ? nil : value
  end

  def privateclaw_optional_env(name)
    value = ENV[name]
    value.nil? || value.empty? ? nil : value
  end

  def privateclaw_optional_file_env(name)
    path = privateclaw_optional_env(name)
    return nil if path.nil?
    UI.user_error!("#{name} file not found: #{path}") unless File.exist?(path)
    path
  end

  def privateclaw_app_review_information
    info = {}
    notes_file = privateclaw_optional_file_env("PRIVATECLAW_APP_REVIEW_NOTES_FILE")
    info[:notes] = File.read(notes_file) unless notes_file.nil?

    {
      first_name: "PRIVATECLAW_APP_REVIEW_FIRST_NAME",
      last_name: "PRIVATECLAW_APP_REVIEW_LAST_NAME",
      phone_number: "PRIVATECLAW_APP_REVIEW_PHONE_NUMBER",
      email_address: "PRIVATECLAW_APP_REVIEW_EMAIL_ADDRESS",
      demo_user: "PRIVATECLAW_APP_REVIEW_DEMO_USER",
      demo_password: "PRIVATECLAW_APP_REVIEW_DEMO_PASSWORD"
    }.each do |key, env_name|
      value = privateclaw_optional_env(env_name)
      info[key] = value unless value.nil?
    end

    info
  end

  def privateclaw_app_review_attachment_file
    privateclaw_optional_file_env("DELIVER_APP_REVIEW_ATTACHMENT_FILE")
  end

  def privateclaw_apply_review_upload_options(options)
    review_info = privateclaw_app_review_information
    options[:app_review_information] = review_info unless review_info.empty?

    attachment = privateclaw_app_review_attachment_file
    options[:app_review_attachment_file] = attachment unless attachment.nil?

    options
  end

  desc "Build an App Store signed IPA for PrivateClaw"
  lane :build_release do
    privateclaw_prepare_ios_build_settings
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic"
      },
      xcargs: privateclaw_signing_xcargs,
      output_directory: "../builds/ios",
      output_name: "PrivateClaw.ipa"
    )
  end

  desc "Upload localized metadata only"
  lane :metadata do
    options = {
      api_key: privateclaw_app_store_api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      force: true,
      precheck_include_in_app_purchases: false
    }
    upload_to_app_store(**privateclaw_apply_review_upload_options(options))
  end

  desc "Upload an existing IPA to TestFlight without rebuilding"
  lane :upload_beta do
    upload_to_testflight(
      api_key: privateclaw_app_store_api_key,
      ipa: "../builds/ios/PrivateClaw.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    build_release
    upload_beta
  end

  desc "Promote the current TestFlight build to external testing"
  lane :promote_external do
    options = {
      api_key: privateclaw_app_store_api_key,
      app_identifier: "gg.ai.privateclaw",
      app_platform: "ios",
      app_version: privateclaw_build_name,
      build_number: privateclaw_build_number,
      distribute_only: true,
      distribute_external: true,
      submit_beta_review: true,
      notify_external_testers: privateclaw_notify_external_testers,
      groups: privateclaw_testflight_external_groups
    }
    changelog = privateclaw_testflight_changelog
    options[:changelog] = changelog unless changelog.nil?
    upload_to_testflight(**options)
  end

  def privateclaw_release_upload_options(skip_binary_upload: false)
    options = {
      api_key: privateclaw_app_store_api_key,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      skip_screenshots: false,
      submit_for_review: true,
      automatic_release: ENV["PRIVATECLAW_AUTOMATIC_RELEASE"] == "true",
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    }
    if skip_binary_upload
      options[:app_version] = privateclaw_build_name
      options[:build_number] = privateclaw_build_number
      options[:skip_binary_upload] = true
    else
      options[:ipa] = "../builds/ios/PrivateClaw.ipa"
    end
    privateclaw_apply_review_upload_options(options)
  end

  desc "Submit the existing App Store Connect build for App Store review"
  lane :upload_release do
    upload_to_app_store(**privateclaw_release_upload_options(skip_binary_upload: true))
  end

  desc "Build and submit a production App Store release"
  lane :release do
    build_release
    upload_to_app_store(**privateclaw_release_upload_options)
  end
end
