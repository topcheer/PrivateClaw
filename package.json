{
  "name": "privateclaw",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @privateclaw/protocol && npm run build --workspace @privateclaw/privateclaw-relay && npm run build --workspace @privateclaw/privateclaw",
    "docker:relay": "scripts/with-relay-env.sh docker compose up --build relay",
    "relay:promote": "node scripts/promote-relay-branch.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:check:staged": "node scripts/check-local-only-files.mjs --staged",
    "store:version": "node scripts/resolve-mobile-version.mjs",
    "store:version:shell": "node scripts/resolve-mobile-version.mjs --shell",
    "store:version:json": "node scripts/resolve-mobile-version.mjs --json",
    "store:check": "node scripts/check-store-readiness.mjs",
    "store:env:ggai": "node scripts/export-store-env-from-ggai.mjs",
    "store:check:ggai": "scripts/with-ggai-store-env.sh npm run store:check",
    "store:screenshots": "scripts/capture-store-screenshots.sh all",
    "store:screenshots:ios": "scripts/capture-store-screenshots.sh ios",
    "store:screenshots:android": "scripts/capture-store-screenshots.sh android",
    "test": "npm run test --workspace @privateclaw/protocol && npm run test --workspace @privateclaw/privateclaw-relay && npm run test --workspace @privateclaw/privateclaw && (cd apps/privateclaw_app && flutter test)",
    "dev:relay": "npm run dev --workspace @privateclaw/privateclaw-relay",
    "demo:provider": "npm run demo --workspace @privateclaw/privateclaw",
    "ios:testflight": "cd apps/privateclaw_app/ios && fastlane beta",
    "ios:testflight:upload": "cd apps/privateclaw_app/ios && fastlane upload_beta",
    "ios:testflight:external": "cd apps/privateclaw_app/ios && fastlane promote_external",
    "ios:testflight:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/ios fastlane beta",
    "ios:testflight:upload:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/ios fastlane upload_beta",
    "ios:testflight:external:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/ios fastlane promote_external",
    "ios:metadata": "cd apps/privateclaw_app/ios && fastlane metadata",
    "ios:metadata:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/ios fastlane metadata",
    "ios:release": "cd apps/privateclaw_app/ios && fastlane release",
    "ios:release:upload": "cd apps/privateclaw_app/ios && fastlane upload_release",
    "ios:release:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/ios fastlane release",
    "ios:release:upload:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/ios fastlane upload_release",
    "android:internal": "cd apps/privateclaw_app/android && fastlane internal",
    "android:internal:upload": "cd apps/privateclaw_app/android && fastlane upload_internal",
    "android:closed": "cd apps/privateclaw_app/android && fastlane closed",
    "android:closed:promote": "cd apps/privateclaw_app/android && fastlane promote_closed",
    "android:internal:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/android fastlane internal",
    "android:internal:upload:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/android fastlane upload_internal",
    "android:closed:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/android fastlane closed",
    "android:closed:promote:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/android fastlane promote_closed",
    "android:metadata": "cd apps/privateclaw_app/android && fastlane metadata",
    "android:metadata:ggai": "scripts/with-ggai-store-env.sh --cwd apps/privateclaw_app/android fastlane metadata",
    "publish:protocol": "npm publish --workspace @privateclaw/protocol --access public",
    "publish:protocol:dry-run": "npm publish --dry-run --workspace @privateclaw/protocol --access public",
    "publish:relay": "npm publish --workspace @privateclaw/privateclaw-relay --access public",
    "publish:relay:dry-run": "npm publish --dry-run --workspace @privateclaw/privateclaw-relay --access public",
    "publish:provider": "npm publish --workspace @privateclaw/privateclaw --access public",
    "publish:provider:dry-run": "npm publish --dry-run --workspace @privateclaw/privateclaw --access public",
    "publish:npm": "npm run publish:protocol && npm run publish:relay && npm run publish:provider",
    "publish:npm:dry-run": "npm run publish:protocol:dry-run && npm run publish:relay:dry-run && npm run publish:provider:dry-run"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
