{
  "name": "@privateclaw/protocol",
  "version": "0.1.1",
  "description": "Protocol types and crypto helpers for PrivateClaw sessions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "privateclaw",
    "protocol",
    "crypto",
    "aes-gcm",
    "relay"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
