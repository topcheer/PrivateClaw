PRIVATECLAW_RELAY_BASE_URL=ws://127.0.0.1:8787
PRIVATECLAW_SESSION_TTL_MS=900000
PRIVATECLAW_PROVIDER_LABEL=PrivateClaw
PRIVATECLAW_WELCOME_MESSAGE=Welcome to PrivateClaw.
# Use one upstream mode: openclaw-agent (default), webhook, or echo.
# PRIVATECLAW_BRIDGE_MODE=openclaw-agent
# PRIVATECLAW_OPENCLAW_AGENT_BRIDGE=true
# PRIVATECLAW_OPENCLAW_AGENT_BIN=openclaw
# PRIVATECLAW_OPENCLAW_AGENT_ID=
# PRIVATECLAW_OPENCLAW_AGENT_CHANNEL=
# PRIVATECLAW_OPENCLAW_AGENT_THINKING=low
# PRIVATECLAW_OPENCLAW_AGENT_TIMEOUT_SECONDS=120
# PRIVATECLAW_OPENCLAW_AGENT_LOCAL=false
# PRIVATECLAW_GATEWAY_BASE_URL=http://127.0.0.1:8080
# PRIVATECLAW_GATEWAY_CHAT_COMPLETIONS_URL=http://127.0.0.1:8080/v1/chat/completions
# PRIVATECLAW_GATEWAY_MODEL=openclaw
# PRIVATECLAW_GATEWAY_API_KEY=
# PRIVATECLAW_GATEWAY_SYSTEM_PROMPT=You are OpenClaw inside a secure PrivateClaw session.
# PRIVATECLAW_ECHO_PREFIX=PrivateClaw demo
# PRIVATECLAW_WEBHOOK_URL=http://127.0.0.1:3000/privateclaw/bridge
# PRIVATECLAW_WEBHOOK_TOKEN=change-me
