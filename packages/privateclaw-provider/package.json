{
  "name": "@privateclaw/privateclaw",
  "version": "0.1.41",
  "description": "PrivateClaw provider runtime and OpenClaw-compatible plugin adapter. iOS App Store (YourClaw): https://apps.apple.com/us/app/yourclaw/id6760531637 ; Android closed alpha requires joining https://groups.google.com/g/gg-studio-ai-products before installing https://play.google.com/store/apps/details?id=gg.ai.privateclaw ; Desktop GitHub Releases (look for app-v*): https://github.com/topcheer/PrivateClaw/releases",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.23"
    },
    "install": {
      "npmSpec": "@privateclaw/privateclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.23"
    },
    "release": {
      "publishToNpm": true
    }
  },
  "bin": {
    "privateclaw-provider": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "tsconfig.json",
    "openclaw.plugin.json",
    "README.md"
  ],
  "keywords": [
    "privateclaw",
    "openclaw",
    "provider",
    "relay",
    "chat",
    "encryption"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "demo": "tsx src/cli.ts",
    "prepack": "npm run build",
    "test": "node --import tsx --test src/*.test.ts src/**/*.test.ts"
  },
  "dependencies": {
    "@privateclaw/protocol": "^0.1.3",
    "fflate": "^0.8.2",
    "qrcode": "^1.5.4",
    "ws": "^8.18.3"
  },
  "peerDependencies": {
    "openclaw": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/topcheer/PrivateClaw.git",
    "directory": "packages/privateclaw-provider"
  },
  "homepage": "https://github.com/topcheer/PrivateClaw/tree/main/packages/privateclaw-provider",
  "bugs": {
    "url": "https://github.com/topcheer/PrivateClaw/issues"
  }
}
